NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/sirde

# JWT — use uma string aleatória longa (mínimo 32 caracteres)
JWT_SECRET=troque-por-um-segredo-aleatorio-com-mais-de-32-caracteres
JWT_EXPIRES_IN=5m
REFRESH_TOKEN_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=10

# URL pública da API (usada para montar links de upload)
APP_URL=http://localhost:3000

# SMTP (opcional — sem estas variáveis, e-mails são apenas logados no console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sirde.com
